# Supabase / PostgreSQL connection string (use the Supabase "Connection pooling"
# URL for serverless-friendly connections). Example:
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Comma-separated CORS origins allowed to call the API (your Netlify site).
# Example: https://vermins-vengeance.netlify.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
